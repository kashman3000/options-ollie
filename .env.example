# Options Ollie — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Google Gemini API key (for enhanced NBA narrative coaching)
# Get one at: https://aistudio.google.com/app/apikey
# If set, this takes precedence over the key stored in data/config.json.
GOOGLE_API_KEY=your_gemini_api_key_here

# Telegram bot (optional — for trade alerts)
# Create a bot via @BotFather to get the token.
# Get your chat ID by messaging @userinfobot.
OLLIE_TELEGRAM_TOKEN=your_telegram_bot_token_here
OLLIE_TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# MenthorQ API (planned — for options flow data, coming July 2026)
# MENTHORQ_API_KEY=your_menthorq_api_key_here
